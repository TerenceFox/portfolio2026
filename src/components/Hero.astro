---
interface Props {
  name: string;
  positioning: string;
}

const { name, positioning } = Astro.props;
---

<section id="hero">
  <div class="hero-portrait">
    <slot name="portrait">
      <img src="/hero.webp" alt={name} class="portrait-image">
    </slot>
  </div>
  <h1>{name}</h1>
  <p class="positioning">{positioning}</p>
</section>
