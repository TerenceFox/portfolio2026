---
const navLinks = [
  { href: '/#about', label: 'About' },
  { href: '/#work', label: 'Work' },
  { href: '/blog/', label: 'Writing' },
];
---

<header>
  <nav>
    <a href="/#hero" class="logo" aria-label="Home"><img src="/wordmark.svg" alt="Terence Fox" class="logo-wordmark"><img src="/logo.png" alt="" class="logo-mark"></a>
    <ul>
      {navLinks.map(({ href, label }) => (
        <li><a href={href}>{label}</a></li>
      ))}
      <li><a href="/terence-fox-resume.pdf" download="" class="nav-resume"><img src="/icon-download.svg" alt="" class="icon">Resume</a></li>
    </ul>
  </nav>
</header>

<script>
  const sections = document.querySelectorAll('main section[id]:not(#hero)');
  const linkEls = document.querySelectorAll<HTMLAnchorElement>('nav ul a');

  function getHash(href: string): string | null {
    const hashIndex = href.indexOf('#');
    return hashIndex === -1 ? null : href.slice(hashIndex + 1);
  }

  function setActiveLink(matcher: (href: string) => boolean) {
    linkEls.forEach(link => {
      link.classList.remove('active');
      const href = link.getAttribute('href') || '';
      if (matcher(href)) {
        link.classList.add('active');
      }
    });
  }

  function setActiveByHash(id: string) {
    setActiveLink(href => getHash(href) === id);
  }

  function setActiveByPath(pathname: string) {
    setActiveLink(href => {
      if (href.startsWith('#') || href.startsWith('/#')) return false;
      if (href === pathname) return true;
      return href.length > 1 && href.endsWith('/') && pathname.startsWith(href);
    });
  }

  if (window.location.pathname !== '/') {
    setActiveByPath(window.location.pathname);
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        setActiveByHash(entry.target.id);
      }
    });
  }, { rootMargin: '-20% 0px -70% 0px' });

  sections.forEach(section => observer.observe(section));

  let clickedRecently = false;
  linkEls.forEach(link => {
    link.addEventListener('click', () => {
      const href = link.getAttribute('href') || '';
      const hash = getHash(href);
      const samePageHash = hash && (href.startsWith('#') || href.startsWith('/#'));
      if (samePageHash && window.location.pathname === '/') {
        setActiveByHash(hash);
        clickedRecently = true;
        setTimeout(() => { clickedRecently = false; }, 1000);
      }
    });
  });

  if (sections.length > 0) {
    let lastScrollY = window.scrollY;
    window.addEventListener('scroll', () => {
      if (clickedRecently) return;
      const scrollingDown = window.scrollY > lastScrollY;
      const scrolledToBottom = (window.innerHeight + window.scrollY) >= document.body.offsetHeight - 50;
      if (scrolledToBottom && scrollingDown) {
        const last = sections[sections.length - 1];
        if (last.id) setActiveByHash(last.id);
      }
      lastScrollY = window.scrollY;
    });
  }
</script>
