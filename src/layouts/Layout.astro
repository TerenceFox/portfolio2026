---
import '../styles/style.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Terence Fox',
  description = 'Terence Fox - Portfolio'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="author" content="Terence Fox">
  <link rel="canonical" href="https://terencefox.com/">

  <!-- Open Graph / Social -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://terencefox.com/">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content="https://terencefox.com/files/og-image.png">

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/files/favicon.ico">
  <link rel="icon" type="image/png" sizes="16x16" href="/files/favicon-16x16.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/files/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="48x48" href="/files/favicon-48x48.png">
  <link rel="apple-touch-icon" href="/files/apple-touch-icon.png">

  <!-- Theme -->
  <meta name="theme-color" content="#000000">
</head>
<body>
  <a href="#main" class="skip-link">Skip to main content</a>
  <slot />
</body>
</html>
